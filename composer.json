{
    "name": "hekal/shipbridge",
    "description": "Unified Laravel shipping abstraction for create, track, label, return, and exchange across carriers",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "shipping", "carriers", "tracking", "labels", "returns", "logistics", "ecommerce"],
    "authors": [{"name": "Mohamed Hekal"}],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {"Hekal\\ShipBridge\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {"Hekal\\ShipBridge\\Tests\\": "tests/"}
    },
    "extra": {
        "laravel": {
            "providers": ["Hekal\\ShipBridge\\ShipBridgeServiceProvider"],
            "aliases": {"ShipBridge": "Hekal\\ShipBridge\\Facades\\ShipBridge"}
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {"pestphp/pest-plugin": true}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
